# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
# The node_modules folder is huge and can always be recreated from package.json
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# Testing
# Coverage reports generated by testing tools like Jest
/coverage

# Production build output
# These folders contain the built/compiled version of your app.
# The exact folder depends on your build tool (CRA, Vite, Next.js, etc.)
/build
/dist
/.next
/out

# Environment variables
# These files often contain API keys and secrets. NEVER commit them!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor directories and files
# These are specific to your code editor and operating system
.idea
.vscode
*.swp
*.swo
.DS_Store
Thumbs.db

# TypeScript
# Cache file used by the TypeScript compiler
*.tsbuildinfo
next-env.d.ts